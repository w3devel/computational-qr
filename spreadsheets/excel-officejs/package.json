{
  "name": "computational-qr-excel",
  "version": "0.1.0",
  "description": "Excel OfficeJS Custom Functions add-in for computational-qr quantum simulation",
  "main": "dist/functions.js",
  "scripts": {
    "build": "webpack --config webpack.config.js --mode production",
    "build:dev": "webpack --config webpack.config.js --mode development",
